# Clerk (Dashboard → API keys; use "Connect with Supabase" for session tokens + role claim)
# Optional: create a JWT template named "supabase" if you use that flow; otherwise the app uses the default session token.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Canonical site URL for share links and Open Graph (e.g. https://lobsmash.com). Falls back to window origin in the browser for dev.
NEXT_PUBLIC_SITE_URL=https://lobsmash.com

# Supabase (Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase: Authentication → Third-party → Clerk
# Use the same Clerk Frontend API domain as in the Clerk dashboard (e.g. https://resolved-bison-62.clerk.accounts.dev).
# No extra env var for that URL in this app—NEXT_PUBLIC_CLERK_* keys identify the instance. RLS uses JWT `sub` as your user id.
#
# Hosted DB (no Supabase CLI): migration order is documented in supabase/HOSTED_SETUP.md
# Minimum for Clerk: run supabase/migrations/20250328120000_clerk_jwt_text_ids.sql if you see uuid errors for user_... ids.
# Optional: supabase/migrations/20250329100000_user_last_seen.sql for last_seen_ip (see docs/CLERK_DASHBOARD.md).
#
# One-time local migration runner (npm run db:migrate:clerk): Postgres URI from
# Supabase → Project Settings → Database → Connection string (include DB password). Never commit this.
# DATABASE_URL=postgresql://postgres.xxx:[PASSWORD]@aws-0-....pooler.supabase.com:6543/postgres
